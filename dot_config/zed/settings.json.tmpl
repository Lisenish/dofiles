// Managed by chezmoi. Edits here are overwritten by chezmoi apply.
// Edit the source instead:  chezmoi edit ~/.config/zed/settings.json
//
// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
{{- if .work }}
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "Mercari LiteLLM",
      "model": "gpt-5.5",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "language_models": {
    "openai_compatible": {
      "Mercari LiteLLM": {
        "api_url": "https://litellm.mercari.in/v1",
        "available_models": [
          {
            "name": "gpt-5.5",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          },
          {
            "name": "claude-opus-4-7",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          }
        ]
      }
    }
  },
{{- end }}
  "icon_theme": "Catppuccin Macchiato",
  "diff_view_style": "split",
  "project_panel": {
    "dock": "left"
  },
  "terminal": {
    "font_family": "MesloLGS NF"
  },
  "git": {
    "inline_blame": {
      "enabled": true
    }
  },
  "base_keymap": "VSCode",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "buffer_font_family": "FiraCode-Retina",
  "file_types": {
    "cue": [
      "*.cue"
    ]
  },
  "colorize_brackets": true,
  "auto_indent_on_paste": true,
  "linked_edits": true,
  "show_whitespaces": "none",
  "show_edit_predictions": true,
  "ensure_final_newline_on_save": true,
  "agent_servers": {
    "cursor": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Macchiato",
  },
}
