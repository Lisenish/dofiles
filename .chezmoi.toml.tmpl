{{- /* Prompt once at `chezmoi init` time; answer persists in ~/.config/chezmoi/chezmoi.toml */ -}}
{{- $work := promptBoolOnce . "work" "Is this a work (Mercari) machine" -}}
[data]
work = {{ $work }}
email = "{{ if $work }}d-ivanov@mercari.com{{ else }}{{ promptStringOnce . "email" "Personal git email" }}{{ end }}"

[edit]
command = "zed"
args = ["--wait"]

[merge]
command = "code"
# VSCode 3-way merge editor: code --merge <local> <remote> <base> <result>
# local=.Destination (your current file), remote=.Target (chezmoi's desired state),
# base & result=.Source — the merged output is written back to the source file.
# Requires the `code` CLI: in VSCode, Cmd+Shift+P → "Shell Command: Install 'code' command in PATH".
args = ["--wait", "--merge", "{{ `{{ .Destination }}` }}", "{{ `{{ .Target }}` }}", "{{ `{{ .Source }}` }}", "{{ `{{ .Source }}` }}"]

[git]
autoPush = true
